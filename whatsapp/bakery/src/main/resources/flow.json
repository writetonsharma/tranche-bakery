{
  "initialState": "IDLE",
  "states": {

    "IDLE": {
      "defaultResponse": "Send *hi* to start ordering from Tranché Bakery! 🥖",
      "transitions": [
        { "match": "hi", "ignoreCase": true, "nextState": "MAIN_MENU" }
      ]
    },

    "MAIN_MENU": {
      "entryMessage": {
        "type": "buttons",
        "body": "Welcome to Tranché Bakery! 🥖\n\n⏰ Orders must be placed *before 6 PM* for next-day delivery. Unfinished orders are cancelled at 6 PM.\n\nWhat would you like to do?\n\n_Send *hi* anytime to start over._",
        "buttons": [
          { "id": "order",   "title": "Order" },
          { "id": "message", "title": "Message Us" },
          { "id": "hours",   "title": "Hours & Info" }
        ]
      },
      "transitions": [
        { "match": "order",   "nextState": "ORDER_SELECT_CATEGORY" },
        { "match": "message", "nextState": "MESSAGE_AWAITING_TEXT" },
        { "match": "hours",   "nextState": "HOURS_INFO" },
        { "match": "*",       "nextState": "MAIN_MENU" }
      ]
    },

    "HOURS_INFO": {
      "entryMessage": {
        "type": "text",
        "body": "🕐 *Bake Days:* Tuesday to Sunday\n🕖 *Order Cutoff:* 6 PM\n\nOrders placed after 6 PM will be prepared for the next available bake day."
      },
      "autoTransition": "MAIN_MENU"
    },

    "AREA_SELECT": {
      "entryMessage": {
        "type": "text",
        "body": "👋 Welcome! We deliver to select areas in Gurgaon.\n\nPlease type your *pincode* to check if we deliver to your area:"
      },
      "transitions": [
        { "match": "*", "nextState": "MAIN_MENU", "saveContext": "pincode", "action": "SAVE_AREA" }
      ]
    },

    "ORDER_SELECT_CATEGORY": {
      "entryMessage": {
        "type": "list",
        "body": "What are you in the mood for? Pick a category:",
        "buttonLabel": "View Categories",
        "dataSource": "MENU_CATEGORIES"
      },
      "transitions": [
        { "match": "*", "nextState": "ORDER_SELECT_ITEM", "saveContext": "categoryId" }
      ]
    },

    "ORDER_SELECT_ITEM": {
      "entryMessage": {
        "type": "list",
        "body": "Choose your item:",
        "buttonLabel": "View Items",
        "dataSource": "MENU_ITEMS"
      },
      "transitions": [
        { "match": "*", "nextState": "ORDER_SELECT_QUANTITY", "saveContext": "itemId" }
      ]
    },

    "ORDER_SELECT_QUANTITY": {
      "entryMessage": {
        "type": "buttons",
        "body": "How many would you like? Tap a button or type 4 or 5:",
        "buttons": [
          { "id": "1", "title": "1" },
          { "id": "2", "title": "2" },
          { "id": "3", "title": "3" }
        ]
      },
      "transitions": [
        { "match": "1", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "2", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "3", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "4", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "5", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "*", "errorMessage": "Please choose a quantity between 1 and 5. Tap a button or type a number." }
      ]
    },

    "ORDER_ADD_MORE": {
      "entryMessage": {
        "type": "buttons",
        "body": "Item added! Would you like to add another item or review your order?",
        "buttons": [
          { "id": "add_item",   "title": "Add Another" },
          { "id": "view_order", "title": "View Order" }
        ]
      },
      "transitions": [
        { "match": "add_item",   "nextState": "ORDER_SELECT_CATEGORY" },
        { "match": "view_order", "nextState": "ADDRESS_GATE" },
        { "match": "*",          "nextState": "ORDER_ADD_MORE" }
      ]
    },

    "ADDRESS_GATE": {
      "entryAction": "ROUTE_TO_ADDRESS_OR_CONFIRM"
    },

    "ADDRESS_COLLECT": {
      "entryMessage": {
        "type": "text",
        "body": "📍 Please type your full delivery address:\n\n_Example: Flat 4B, Tower 2, Emerald Hills, Golf Course Extension Road_"
      },
      "transitions": [
        { "match": "*", "nextState": "LOCATION_SHARE", "saveContext": "deliveryAddress", "action": "SAVE_DELIVERY_ADDRESS" }
      ]
    },

    "LOCATION_SHARE": {
      "entryMessage": {
        "type": "text",
        "body": "📌 Almost there! Please share your location pin so we can find you on delivery day.\n\nTap the 📎 paperclip icon → *Location* → send your *pinned location* (not live location)."
      },
      "transitions": [
        { "matchType": "location", "nextState": "ORDER_CONFIRM", "action": "SAVE_LOCATION" }
      ]
    },

    "ORDER_CONFIRM": {
      "entryAction": "SHOW_ORDER_SUMMARY",
      "transitions": [
        { "match": "confirm", "nextState": "PAYMENT_PENDING", "action": "CONFIRM_ORDER" },
        { "match": "cancel",  "nextState": "MAIN_MENU",       "action": "CANCEL_ORDER"  }
      ]
    },

    "PAYMENT_PENDING": {
      "entryMessage": {
        "type": "text",
        "body": "💳 *Payment Instructions*\n\nPlease complete your UPI payment and send a screenshot here.\n\n*UPI ID:* bakery@upi\n\nOnce we receive your screenshot, we will confirm your order shortly."
      },
      "transitions": [
        { "matchType": "image", "nextState": "PAYMENT_RECEIVED", "action": "SAVE_PAYMENT_SCREENSHOT" }
      ]
    },

    "PAYMENT_RECEIVED": {
      "entryMessage": {
        "type": "text",
        "body": "✅ Thank you! We've received your payment screenshot and will verify it shortly.\n\nYou will get a confirmation once your order is confirmed. We appreciate your patience!"
      },
      "autoTransition": "IDLE"
    },

    "MESSAGE_AWAITING_TEXT": {
      "entryMessage": {
        "type": "text",
        "body": "💬 Got feedback, a question, a complaint, or a special request? Type your message below and we'll get back to you personally."
      },
      "transitions": [
        { "match": "*", "nextState": "MESSAGE_DONE", "action": "SAVE_FEEDBACK" }
      ]
    },

    "MESSAGE_DONE": {
      "entryMessage": {
        "type": "text",
        "body": "Thank you for reaching out! We've received your message and will get back to you if needed. 😊"
      },
      "autoTransition": "IDLE"
    }

  }
}
